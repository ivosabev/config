{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "node": true
  },
  "ignorePatterns": [
    "**/.cache/**",
    "**/node_modules/**",
    "**/build/**",
    "**/public/build/**",
    "**/playwright-report/**",
    "**/server-build/**",
    "**/dist/**"
  ],
  "options": {
    "typeAware": true
  },
  "overrides": [
    {
      "files": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "!**/tests/**", "!**/#tests/**", "!**/__tests__/**/*", "!**/*.test.*"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["**/tests/**", "**/#tests/**", "**/__tests__/**/*", "**/*.test.*"],
                "message": "Do not import test files in source files"
              }
            ]
          }
        ]
      }
    }
  ],
  "plugins": ["import", "react", "vitest", "typescript"],
  "rules": {
    "curly": ["error", "all"],
    "import/consistent-type-specifier-style": ["warn", "prefer-inline"],
    "import/no-duplicates": ["warn", {"preferInline": true}],
    "no-func-assign": "error",
    "no-global-assign": "error",
    "no-unexpected-multiline": "error",
    "no-unused-expressions": [
      "error",
      {
        "allowShortCircuit": true,
        "allowTaggedTemplates": true,
        "allowTernary": true
      }
    ],
    "no-unused-vars": [
      "warn",
      {
        "args": "after-used",
        "argsIgnorePattern": "^_",
        "caughtErrors": "all",
        "caughtErrorsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_",
        "ignoreRestSiblings": true,
        "varsIgnorePattern": "^_"
      }
    ],
    "no-use-before-define": [
      "error",
      {
        "classes": false,
        "functions": false,
        "typedefs": false,
        "variables": false
      }
    ],
    "no-warning-comments": ["error", {"location": "anywhere", "terms": ["FIXME"]}],
    "react/exhaustive-deps": "warn",
    "react/jsx-key": "warn",
    "react/jsx-no-undef": "error",
    "react/require-render-return": "error",
    "react/rules-of-hooks": "error",
    "sort-keys": "warn",
    "typescript/consistent-type-imports": [
      "warn",
      {
        "disallowTypeAnnotations": true,
        "fixStyle": "inline-type-imports",
        "prefer": "type-imports"
      }
    ],
    "typescript/no-misused-promises": ["error", {"checksVoidReturn": false}],
    "typescript/return-await": "error",
    "vitest/no-focused-tests": "warn"
  }
}
